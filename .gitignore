cat > .gitignore << 'EOF'

# -----------------------

# Data & large artifacts

# -----------------------

data/**

artifacts/**

 

# Keep folder placeholders

!data/.gitkeep

!artifacts/.gitkeep

 

# -----------------------

# Jupyter / notebooks

# -----------------------

.ipynb_checkpoints/

**/.ipynb_checkpoints/

*.nbconvert.ipynb

 

# -----------------------

# Python bytecode / caches

# -----------------------

__pycache__/

**/__pycache__/

*.py[cod]

*.pyo

*.pyd

*.so

 

# -----------------------

# Virtual envs / conda / env files

# -----------------------

.env

.env.*

.venv/

venv/

ENV/

env/

environment.local.yml

*.conda

 

# -----------------------

# OS / editor noise

# -----------------------

.DS_Store

Thumbs.db

*.swp

*.swo

*.tmp

.vscode/

.idea/

 

# -----------------------

# Logs & outputs you use these)# Logs & outputs

# -----------------------

# mlruns/

# wandb/

# lightning_logs/

# tensorboard/

EOF

# -----------------------

*.log

logs/

reports/**/*.html

 

# -----------------------
