# -----------------------
# Data & large artifacts
# -----------------------
data/**
artifacts/**
!data/.gitkeep
!artifacts/.gitkeep
!artifacts/baselines/lgbm_numeric_v1_subsample/*.json
!artifacts/baselines/lgbm_numeric_v1_subsample/*.md

# Ignore office/libreoffice lock files etc.
.~lock.*

# (Optional) direnv (if you use it later)
.envrc
.direnv/

# Avoid accidental in-repo runs (real runs live in external RUNS_DIR)
runs/
mlruns/



# -----------------------
# Jupyter / notebooks
# -----------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.nbconvert.ipynb

# Allow executed notebooks ONLY in notebooks/reports (do not ignore it)
notebooks/_scratch/

# -----------------------
# Python bytecode / caches
# -----------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# -----------------------
# Virtual envs / conda / env files
# -----------------------
.env
.env.*
.venv/
venv/
ENV/
env/
environment.local.yml
*.conda

# -----------------------
# OS / editor noise
# -----------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp
.vscode/
.idea/

# -----------------------
# Logs
# -----------------------
*.log
logs/

# Top-level reports: keep for curated outputs only (don’t blanket-ignore)
# reports/**/*.html

# Packaging
*.egg-info/
dist/
build/

# -----------------------
# Old file versions
# -----------------------
# Baseline reports (generated)
artifacts/baselines/**/report_v*.csv
