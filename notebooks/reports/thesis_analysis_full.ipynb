# Fraud Thesis Results Analysis — Aligned to Real Data

## 1. Setup and Imports

import json
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import Path

sns.set_theme()
ARTIFACTS = Path("../miniature-fishstick/artifacts/baselines/lgbm_numeric_v1_subsample")
OUTPUT = Path("../miniature-fishstick/output")

## 2. Load Data

# EO — one record per event_id
eo_path = ARTIFACTS / "eos_test_with_drivers.jsonl"
with open(eo_path) as f:
    eo = [json.loads(line) for line in f]
eo_df = pd.DataFrame(eo)

# LLM narrative — join on eo_event_id
llm_path = OUTPUT / "narratives_ops_triage_llm.jsonl"
with open(llm_path) as f:
    llm = [json.loads(line) for line in f]
llm_df = pd.DataFrame(llm)

print(f"EOs loaded: {len(eo_df)}")
print(f"LLM narratives loaded: {len(llm_df)}")

## 3. Join EO + Narrative for Analysis

merged = eo_df.merge(
    llm_df,
    left_on="event_id", right_on="eo_event_id",
    suffixes=("_eo", "_llm"),
)
print(f"Merged records: {len(merged)}")

## 4. Metrics: Overlap and Direction (from LLM metrics)

# Each LLM output already has "metrics" block with overlap_at_K, direction_accuracy, etc.
metrics_df = merged["narrative"].apply(lambda n: n.get("metrics", {})).apply(pd.Series)
merged = pd.concat([merged, metrics_df], axis=1)

# Summarize mean overlap, direction, action consistency
metric_cols = ["overlap_at_K", "direction_accuracy", "action_consistency", "thin_file_action_valid"]
summary = {c: merged[c].mean() if pd.api.types.is_bool_dtype(merged[c]) or "overlap" in c else merged[c].sum() for c in metric_cols}

print("Mean metrics for this set:")
for k, v in summary.items():
    print(f"  {k}: {v:.2f}" if isinstance(v, float) else f"  {k}: {v}")

sns.histplot(merged["overlap_at_K"], bins=4)
plt.title("Driver Overlap@K (LLM Output)")
plt.show()

sns.histplot(merged["direction_accuracy"].astype(int))
plt.title("Direction Accuracy (LLM Output)")
plt.show()

## 5. Validator Metrics (Pass/Retry/Fail)

validator_path = ARTIFACTS / "openai_validator_metrics_ops_triage_top5.json"
with open(validator_path) as f:
    validator = json.load(f)

print("Validator Metrics Summary:")
print(json.dumps(validator, indent=2))

if "retries_histogram" in validator:
    hist = validator["retries_histogram"]
    labels = list(hist.keys())
    vals = list(hist.values())
    plt.bar(labels, vals)
    plt.title("Validator Retry Histogram")
    plt.xlabel("Number of retries until pass")
    plt.ylabel("Count")
    plt.show()

if "counts" in validator:
    plt.bar(validator["counts"].keys(), validator["counts"].values())
    plt.title("Validator Status Counts")
    plt.show()

## 6. Optional: Fidelity/Drivers per Sample

for i, row in merged.iterrows():
    print(f"\nEO event_id: {row['event_id']}")
    print("EO drivers:", [d["name"] for d in row["top_drivers"]])
    print("Narr drivers:", row["narrative"]["drivers_used"])
    print("Narrative summary:", row["narrative"]["summary"])
    print("Metrics:", row.get("metrics", ""))
    if i >= 2: break  # show the first 3 only

